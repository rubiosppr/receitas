<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Minhas Receitas</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #333; }
    .page-container { width: 100%; max-width: 1180px; margin: 30px auto; padding: 30px; background: #ffffff; border-radius: 24px; box-shadow: 0 30px 80px rgba(0,0,0,0.13); }
    .page-header { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 28px; }
    .page-header h1 { font-size: 2rem; color: #2f2f6c; }
    .nav-links { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
    .nav-links a { color: #667eea; text-decoration: none; font-weight: 600; }
    .nav-links span { color: #555; }
    .btn-primary { display: inline-flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 14px; padding: 12px 22px; cursor: pointer; font-weight: 600; text-decoration: none; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 18px 32px rgba(102, 126, 234, 0.24); }
    .card { background: #f8fbff; border: 1px solid #e6ebfb; border-radius: 20px; padding: 22px; }
    .table-responsive { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 720px; }
    th, td { padding: 16px 14px; text-align: left; border-bottom: 1px solid #e6ebfb; }
    th { background: #f2f6ff; color: #4a4a7d; font-weight: 700; }
    td { color: #444; vertical-align: middle; }
    a.action-link, button.action-btn { color: #667eea; text-decoration: none; font-weight: 600; background: none; border: none; cursor: pointer; }
    a.action-link:hover, button.action-btn:hover { text-decoration: underline; }
    .empty-state { padding: 36px; border-radius: 18px; background: #ffffff; border: 1px dashed #d4d8ee; color: #6b6f8a; text-align: center; }
    .badge { display: inline-flex; flex-wrap: wrap; gap: 6px; }
    .badge span { background: #eef2ff; color: #4a4a7d; border-radius: 999px; padding: 4px 10px; font-size: 0.9rem; }
    @media (max-width: 768px) { .page-header { flex-direction: column; align-items: stretch; } table { min-width: 100%; } }
  </style>
</head>
<body>
  <div class="page-container">
    <div class="page-header">
      <h1>Minhas Receitas</h1>
      <div class="nav-links">
        <span>Olá, <strong><%= alunoName || 'User' %></strong></span>
        <a href="/aluno/habilidades">Habilidades</a>
        <a href="/logout">Sair</a>
        <a style="color: #f2f6ff;" href="/aluno/receitas/new" class="btn-primary">+ Nova Receita</a>
      </div>
    </div>

    <div class="card">
      <% if (receitas && receitas.length > 0) { %>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Link</th>
                <th>Categorias</th>
                <th>Alunos</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% receitas.forEach(receita => { %>
                <tr>
                  <td><%= receita.id %></td>
                  <td><%= receita.name %></td>
                  <td><%= receita.description ? receita.description.substring(0, 50) + (receita.description.length > 50 ? '...' : '') : '-' %></td>
                  <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
  <% if (receita.externalLink) { %>
    <a href="<%= receita.externalLink %>" target="_blank" style="color: #667eea; text-decoration: none;">Link</a>
  <% } else { %>
    -
  <% } %>
</td>
                  <td><%= receita.Categorias && receita.Categorias.length > 0 ? receita.Categorias.map(cat => cat.name).join(', ') : 'Nenhuma' %></td>
                  <td><%= receita.Alunos && receita.Alunos.length > 0 ? receita.Alunos.map(aluno => aluno.name).join(', ') : '-' %></td>
                  <td>
                    <a href="/aluno/receitas/<%= receita.id %>/edit" class="action-link">Editar</a>
                    <form method="POST" action="/aluno/receitas/<%= receita.id %>/delete" style="display:inline; margin-left:10px;" onsubmit="return confirm('Tem certeza que deseja deletar?');">
                      <button type="submit" class="action-btn">Deletar</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          Você ainda não cadastrou receitas. <a href="/aluno/receitas/new">Crie uma agora!</a>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
