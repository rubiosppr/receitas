<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= formTitle %></title>
</head>
<body>
  <h1><%= formTitle %></h1>
  <form method="POST" action="<%= formAction %>">
    <div>
      <label>Name</label>
      <input type="text" name="name" value="<%= receita.name || '' %>" required />
    </div>
    <div>
      <label>Description</label>
      <textarea name="description"><%= receita.description || '' %></textarea>
    </div>
    <div>
      <label>External Link</label>
      <input type="text" name="externalLink" value="<%= receita.externalLink || '' %>" />
    </div>
    <div>
      <label>Categories</label>
      <select name="categoryIds" multiple size="5">
        <% categorias.forEach((categoria) => { %>
          <option value="<%= categoria.id %>" <%= selectedCategoryIds.includes(categoria.id.toString()) ? 'selected' : '' %>><%= categoria.name %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label>Alunos</label>
      <select name="alunoIds" multiple size="5">
        <% alunos.forEach((aluno) => { %>
          <option value="<%= aluno.id %>" <%= selectedAlunoIds.includes(aluno.id.toString()) ? 'selected' : '' %>><%= aluno.name %></option>
        <% }); %>
      </select>
    </div>
    <button type="submit"><%= submitLabel %></button>
  </form>
</body>
</html>
