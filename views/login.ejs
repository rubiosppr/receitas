<!DOCTYPE html>
      <html lang="pt-BR">
        <head>
          <meta charset="UTF-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <title>🍳 Login - Sistema de Receitas</title>
          <style>
            * {
              margin: 0;
              padding: 0;
              box-sizing: border-box;
            }

            body {
              font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
              background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
              min-height: 100vh;
              display: flex;
              flex-direction: column;
              align-items: center;
              justify-content: flex-start;
              padding: 20px;
            }

            .login-container {
              background: white;
              border-radius: 15px;
              box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
              width: 100%;
              max-width: 450px;
              padding: 50px 40px;
            }

            .login-header {
              text-align: center;
              margin-bottom: 40px;
            }

            .login-header h1 {
              color: #667eea;
              font-size: 2.5em;
              margin-bottom: 10px;
            }

            .login-header p {
              color: #666;
              font-size: 1em;
            }

            .form-group {
              margin-bottom: 20px;
            }

            .form-group label {
              display: block;
              color: #555;
              font-weight: 500;
              margin-bottom: 8px;
              font-size: 0.95em;
            }

            .form-group input {
              width: 100%;
              padding: 12px 15px;
              border: 2px solid #e0e0e0;
              border-radius: 8px;
              font-size: 1em;
              transition: all 0.3s;
            }

            .form-group input:focus {
              outline: none;
              border-color: #667eea;
              box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            }

            .submit-btn {
              width: 100%;
              padding: 12px;
              background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
              color: white;
              border: none;
              border-radius: 8px;
              font-size: 1.05em;
              font-weight: 600;
              cursor: pointer;
              transition: all 0.3s;
              margin-top: 10px;
            }

            .submit-btn:hover {
              transform: translateY(-2px);
              box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
            }

            .divider {
              margin: 30px 0;
              position: relative;
              text-align: center;
              color: #999;
            }

            .divider::before {
              content: '';
              position: absolute;
              top: 50%;
              left: 0;
              right: 0;
              height: 1px;
              background: #e0e0e0;
            }

            .divider span {
              background: white;
              padding: 0 15px;
              position: relative;
            }

            .test-credentials {
              background-color: #f9f9f9;
              padding: 20px;
              border-radius: 8px;
              border-left: 4px solid #667eea;
              font-size: 0.9em;
            }

            .test-credentials h3 {
              color: #333;
              margin-bottom: 15px;
              font-size: 0.95em;
            }

            .test-credentials p {
              color: #666;
              margin-bottom: 8px;
              line-height: 1.5;
            }

            .test-credentials strong {
              color: #667eea;
            }

            .footer-link {
              text-align: center;
              margin-top: 20px;
              font-size: 0.9em;
              color: #666;
            }

            .footer-link a {
              color: #667eea;
              text-decoration: none;
            }

            .footer-link a:hover {
              text-decoration: underline;
            }

            @media (max-width: 480px) {
              .login-container {
                padding: 30px 20px;
              }

              .login-header h1 {
                font-size: 2em;
              }
            }
          </style>
        </head>
        <body>
          <div class="login-container">
            <div class="login-header">
              <h1>🍳</h1>
              <h1>Receitas</h1>
              <p>Sistema de Receitas Culinárias</p>
            </div>

            <form method="POST" action="/login">
              <div class="form-group">
                <label for="email">📧 Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  placeholder="seu@email.com"
                  required 
                  autofocus
                />
              </div>

              <div class="form-group">
                <label for="password">🔐 Senha</label>
                <input 
                  type="password" 
                  id="password" 
                  name="password" 
                  placeholder="••••••••"
                  required 
                />
              </div>

              <button type="submit" class="submit-btn">🚀 Entrar no Sistema</button>
            </form>

            <div class="divider"><span>Dados de Teste</span></div>

            <div class="test-credentials">
              <h3>👑 Administrador</h3>
              <p><strong>Email:</strong> admin@example.com</p>
              <p><strong>Senha:</strong> admin123</p>

              <h3 style="margin-top: 15px;">👨‍🍳 Aluno</h3>
              <p><strong>Email:</strong> aluno1@example.com</p>
              <p><strong>Senha:</strong> password1</p>
            </div>
          </div>
          <div style="width: 100%; max-width: 1000px; margin: 50px auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); overflow-x: auto;">
  <h2 style="color: #667eea; text-align: center; margin-bottom: 20px;">📖 Receitas da Comunidade</h2>
  
  <% if (receitas && receitas.length > 0) { %>
    <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
      <thead>
        <tr style="background-color: #f5f5f5;">
          <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">Nome</th>
          <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">Descrição</th>
          <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">Categoria</th>
          <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">Link</th>
          <th style="padding: 12px; text-align: left; border-bottom: 2px solid #e0e0e0;">Criada por</th>
        </tr>
      </thead>
      <tbody>
        <% receitas.forEach(receita => { %>
          <tr>
            <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;"><strong><%= receita.name %></strong></td>
            <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-size: 0.9em; color: #555;">
              <%= receita.description || 'Sem descrição' %>
            </td>
            <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
              <span style="background: #e0e7ff; color: #4338ca; padding: 4px 8px; border-radius: 12px; font-size: 0.8em;">
                <%= receita.Categorias ? receita.Categorias.name : 'N/A' %>
              </span>
            </td>
            <td style="padding: 12px; border-bottom: 1px solid #f0f0f0;">
              <% if (receita.link) { %>
                <a href="<%= receita.link %>" target="_blank" style="color: #667eea; text-decoration: none;">Ver Link</a>
              <% } else { %>
                -
              <% } %>
            </td>
            <td style="padding: 12px; border-bottom: 1px solid #f0f0f0; font-size: 0.9em;">
              <%= receita.Alunos ? receita.Alunos.map(a => a.name).join(', ') : 'Desconhecido' %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p style="text-align: center; color: #999;">Ainda não há receitas cadastradas.</p>
  <% } %>
</div>
        </body>
      </html>